doctype html
html(lang="es")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        link(rel="stylesheet", href="/style/index.css")
        block head
    body
        header
            nav(data-user-id=(user ? user.id : ''))
                h1#siteName: a(href="/") Fotaza
                form#searchBar(action="/search", method="get")
                    input#searchInput(type="text", name="q", autocomplete='off' ,placeholder='Buscar...')
                    button#glass(type="submit") 🔍
                    #searchHelper
                        .searchOption
                            label(for="tags") Tags
                            input(type="checkbox", name="tags", checked)
                        .searchOption
                            label(for="username") Usuario
                            input(type="checkbox", name="username")
                        .searchOption
                            label(for="title") Título
                            input(type="checkbox", name="title")
                            
                ul
                    if user
                        li: a(href='/moderation') ⚡
                        li: a(href='/post/create') 📝
                        li: a(href='/notifications') 🔔
                            if notificationsCount > 0
                                #notificationsCount.notificationsCount: span #{notificationsCount}
                        li: a(href='/collections') 🗂️
                        li: a(href='/mail') ✉️
                            if unreadedMailCount > 0
                                #unreadedMailCount.notificationsCount: span #{unreadedMailCount}
                        li: a(href="/profile") 👤
                        li: form(action="/logout", method="post"): button(type="submit") 🚪
                    else
                        li: a(href="/login") Iniciar Sesión
                        li: a(href="/signup") Crear Cuenta
        main
            block main
    block scripts
    
    script(src="/script/index.js")